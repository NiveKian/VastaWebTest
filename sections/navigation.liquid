{% stylesheet %}
  .navigation {
    background: var(--color-background);
  }

  .navigation__container {
    max-width: var(--page-width);
    margin: 0 auto;

    display: flex;
    justify-content: center;
    align-items: center;
    /* gap: 2rem; */
  }

  .navigation__item {
    position: relative;
    overflow: hidden;

    text-decoration: none;

    color: #252525;
    font-weight: 700;

    font-size: 1rem;

    padding: 1rem 3rem;
    border-radius: 6px 6px 0 0;

    transition: background 0.2s ease;
  }

  .navigation__item::before {
    content: "";
    position: absolute;

    left: 0;
    bottom: 0;

    width: 100%;
    height: 0;

    background: rgba(0, 0, 0, 0.08);

    transition: height 0.25s ease;
    z-index: 0;
  }

  .navigation__item:hover::before {
    height: 100%;
  }

  .navigation__item span,
  .navigation__item {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .navigation {
      display: none;
    }
  }
{% endstylesheet %}

