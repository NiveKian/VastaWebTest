<section class="review full-width">
  <!-- ===================== -->
  <!-- HEADER -->
  <!-- ===================== -->
  <div class="review__header">
    <h2>{{ section.settings.title }}</h2>

    <div class="review__summary">
      <span>{{ section.settings.subtitle }}</span>

      <div class="stars">
        {% for i in (1..5) %}
          <img src="{{ 'icons/star.svg' | asset_url }}" width="10" height="10" alt="star">
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- ===================== -->
  <!-- REVIEWS GRID -->
  <!-- ===================== -->
  <div class="review__grid" id="reviewGrid">
    {% assign reviews = shop.metaobjects.review.values %}
    {% for review in reviews %}
      <div class="review__card" data-index="{{ forloop.index0 }}">
        <!-- IMAGE -->
        {% if review.persona_img != blank %}
          <img
            src="{{ review.persona_img | image_url: width: 500 }}"
            width="216"
            height="306"
            alt="{{ review.persona_name }}"
          >
        {% endif %}

        <!-- CONTENT -->
        <div class="review__content">
          <!-- NAME -->
          <div class="review__content--persona">
            <strong>{{ review.persona_name }}</strong>
            <span>{{ review.persona_location }}</span>
          </div>

          <!-- STARS -->
          {% assign rating = review.stars.value | remove: '.0' | plus: 0 %}
          <div class="review__content--stars">
            {% for i in (1..5) %}
              {% if i <= rating %}
                <img
                  src="{{ 'icons/star.svg' | asset_url }}"
                  width="10"
                  height="10"
                  alt="star"
                >
              {% endif %}
            {% endfor %}
          </div>

          <!-- TEXT -->
          <div class="review__text">
            <p>{{ review.content }}</p>

            <div class="divider"></div>

            <div class="review__product">
              {% if review.product_img != blank %}
                <img
                  src="{{ review.product_img | image_url: width: 100 }}"
                  width="28"
                  height="28"
                >
              {% endif %}

              <span>{{ review.product_name }}</span>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- ===================== -->
  <!-- PAGINATION -->
  <!-- ===================== -->
  <div class="review__pagination" id="reviewPagination"></div>
</section>

{% stylesheet %}
  .review {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* HEADER */
  .review__header {
    text-align: center;
    padding: 2.2rem;
  }

  .review__header h2 {
    font-size: 2.25rem; /* ~36px */
    font-weight: 700;
    color: #252525;
  }

  .review__summary {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  .review__summary span {
    font-size: 1rem;
  }

  /* GRID */
  .review__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* CARD */
  .review__card {
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    overflow: hidden;
    width: 13.5rem; /* ~216px */
  }

  /* IMAGE */
  .review__card img {
    width: 100%;
    height: 19rem; /* ~306px */
    object-fit: cover;
  }

  /* CONTENT */
  .review__content {
    display: flex;
    flex-direction: column;
  }

  .review__content--persona {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1rem;
  }

  .review__content strong {
    font-size: 1.25rem;
  }

  .review__content span {
    font-size: 0.875rem;
  }

  /* STARS */

  .review__content--stars {
    display: flex;
    align-items: center;
    flex-direction: row;
    gap: 0.1rem;
    padding: 0 1rem;
  }

  .review__content--stars img {
    height: 10px;
    width: 10px;
  }

  /* TEXT */
  .review__text p {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .divider {
    height: 1px;
    background: #ddd;
    margin: 0 1rem;
  }

  /* PRODUCT */
  .review__product {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0;
  }

  .review__product span {
    font-size: 0.75rem;
  }

  .review__product img {
    width: 4rem;
    height: auto;
  }

  /* PAGINATION */
  .review__pagination {
    display: flex;
    gap: 0.75rem;
  }

  .review__pagination span {
    cursor: pointer;
    font-size: 1rem;
    color: #888;
  }

  /* TABLET */
  @media (max-width: 1024px) {
    .review__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* MOBILE */
  @media (max-width: 600px) {
    .review__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Review Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Real Reviews, Real Experiences"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Summary text",
      "default": "With 1600+ 5-star reviews"
    }
  ],
  "presets": [
    {
      "name": "Reviews"
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.review__card');
    const pagination = document.getElementById('reviewPagination');

    const perPage = 4;
    let currentPage = 1;

    const totalPages = Math.ceil(cards.length / perPage);

    const renderPage = (page) => {
      cards.forEach((card, i) => {
        card.style.display = i >= (page - 1) * perPage && i < page * perPage ? 'block' : 'none';
      });
    };

    const renderPagination = () => {
      pagination.innerHTML = '';

      for (let i = 1; i <= Math.min(totalPages, 3); i++) {
        const el = document.createElement('span');
        el.textContent = i;

        el.addEventListener('click', () => {
          currentPage = i;
          renderPage(currentPage);
        });

        pagination.appendChild(el);
      }

      if (totalPages > 3) {
        const dots = document.createElement('span');
        dots.textContent = '...';
        pagination.appendChild(dots);

        const last = document.createElement('span');
        last.textContent = totalPages;
        last.onclick = () => {
          currentPage = totalPages;
          renderPage(currentPage);
        };
        pagination.appendChild(last);
      }
    };

    renderPage(currentPage);
    renderPagination();
  });
</script>
