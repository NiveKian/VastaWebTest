<div class="top-bar full-width">
  <div class="top-bar__content">
    <!-- Left: Email -->
    <div class="top-bar__item top-bar__item--icon">
      <img
        src="{{ 'email.svg' | asset_url }}"
        alt="Email icon"
        width="16"
        height="16"
        class="top-bar__icon"
      >
      <span>{{ section.settings.topbar_email }}</span>
    </div>

    <!-- Center: Message -->
    <div class="top-bar__item top-bar__item--center">
      <span>{{ section.settings.topbar_message }}</span>
    </div>

    <!-- Right: Phone -->
    <div class="top-bar__item top-bar__item--icon">
      <img
        src="{{ 'phone.svg' | asset_url }}"
        alt="Phone icon"
        width="16"
        height="16"
        class="top-bar__icon"
      >
      <span>{{ section.settings.topbar_phone }}</span>
    </div>
  </div>
</div>

{% stylesheet %}
  /* Top bar container */

  .top-bar {
    background-color: var(--color-foreground);
    color: #ffffff;

    height: clamp(40px, 3.5vw, 50px);

    display: flex;
    align-items: center;
  }

  /* Inner content aligned to page width */

  .top-bar__content {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);

    width: 100%;
    height: 100%;

    display: flex;
    align-items: center;
    justify-content: space-around;
  }

  /* Each item */

  .top-bar__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    font-size: clamp(0.875rem, 1.25vw, 1.125rem);
  }

  /* Center text */

  .top-bar__item--center {
    justify-content: center;
    text-align: center;
  }

  /* Left aligns naturally, right needs push */

  .top-bar__content > .top-bar__item:last-child {
    justify-content: flex-end;
  }

  /* Icons */

  .top-bar__icon {
    width: 1rem;
    height: 1rem;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .top-bar__content {
      justify-content: space-between;
    }

    .top-bar__item--icon span {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.top-bar",
  "settings": [
    {
      "type": "text",
      "id": "topbar_email",
      "label": "Email",
      "default": "info@brand.com"
    },
    {
      "type": "text",
      "id": "topbar_message",
      "label": "Center message",
      "default": "WE PAY SHIPPING ON ORDERS OVER $100"
    },
    {
      "type": "text",
      "id": "topbar_phone",
      "label": "Phone",
      "default": "+1 (111) 222-3333"
    }
  ]
}
{% endschema %}
